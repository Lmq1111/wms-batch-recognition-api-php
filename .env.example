# Required for DashScope / Alibaba Cloud Model Studio
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key

# Optional API token for callers. If empty, /api/wms/* endpoints do not require caller auth.
# For integration environments, set a shared token and call with Authorization or X-API-Key.
WMS_API_TOKEN=

# Optional runtime settings
AI_MODEL=qwen3.6-flash
AI_API_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
AI_MAX_TOKENS=900
AI_TIMEOUT_MS=3000
CORS_ALLOW_ORIGIN=*
MAX_JSON_BYTES=18874368
RECOGNITION_LOG_PATH=logs/recognition-events.jsonl
LOG_RETENTION_DAYS=180
